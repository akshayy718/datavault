# ─────────────────────────────────────────────────────────────
# DataVault — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to git (it's in .gitignore).
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# Local development: uses SQLite (auto-created file, no setup needed)
DATABASE_URL=sqlite:///./datavault_dev.db
# Production on Render: Render fills this in automatically from the
# PostgreSQL database it creates for you. Format looks like:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth ──────────────────────────────────────────────────────
# A long random secret string used to sign JWT tokens.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# On Render: set this manually in the Environment Variables dashboard.
JWT_SECRET=change-me-to-a-long-random-string

# ── AI (optional) ─────────────────────────────────────────────
# Free Groq API key from https://console.groq.com
# Leave blank to disable AI features.
AI_PROVIDER_API_KEY=
AI_PROVIDER_BASE_URL=https://api.groq.com/openai/v1
AI_PROVIDER_MODEL=llama-3.3-70b-versatile

# ── BYOK encryption (optional) ────────────────────────────────
# Only needed if users will supply their own AI keys.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BYOK_ENCRYPTION_KEY=

# ── Frontend (Next.js) ────────────────────────────────────────
# Set this in Vercel's Environment Variables dashboard to your Render backend URL.
# Example: NEXT_PUBLIC_API_URL=https://datavault-api.onrender.com/api/v1
# Local development: leave as localhost
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
