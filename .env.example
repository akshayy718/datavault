# Copy this file to .env and fill in real values. Never commit the real .env.

# App
APP_ENV=development
APP_BASE_URL=http://localhost:3000
RECIPIENT_APP_BASE_URL=http://localhost:3001

# Database
# For local development, SQLite needs no setup at all:
DATABASE_URL=sqlite:///./datavault_dev.db
# For production, point this at a managed PostgreSQL instance instead, e.g.:
# DATABASE_URL=postgresql://user:password@host:5432/datavault

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# Google login -- get this from Google Cloud Console (OAuth 2.0 Client ID,
# "Web application" type). Required only for POST /auth/google to work.
GOOGLE_OAUTH_CLIENT_ID=

# AI Provider -- get a free API key from https://console.groq.com
# Required only for the /ai/query and /ai/anomalies endpoints to work.
# Without this set, those two endpoints return a clear 503 explaining why.
AI_PROVIDER_API_KEY=
AI_PROVIDER_BASE_URL=https://api.groq.com/openai/v1
AI_PROVIDER_MODEL=llama-3.3-70b-versatile

# BYOK key encryption (Module 14) -- required only if you want to use
# the BYOK feature (users supplying their own AI provider key). Generate
# one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BYOK_ENCRYPTION_KEY=
